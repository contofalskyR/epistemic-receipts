generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReviewConfidence {
  HIGH
  MEDIUM
  LOW
}

model Claim {
  id                    String            @id @default(cuid())
  text                  String
  createdAt             DateTime          @default(now())
  currentStatus         String            @default("DISPUTED") // DEPRECATED — use epistemicAxis. Values: DISPUTED | HARD_FACT | NEVER_RESOLVES | VERIFIED
  claimType             String            @default("EMPIRICAL") // EMPIRICAL | INSTITUTIONAL | INTERPRETIVE | HYBRID
  parentClaimId         String?
  claimEmergedAt        DateTime?
  claimEmergedPrecision String? // DAY | MONTH | QUARTER | YEAR
  ingestedBy            String            @default("manual")
  humanReviewed         Boolean           @default(false)
  reviewConfidence      ReviewConfidence?
  reviewedAt            DateTime?
  reviewedBy            String?
  externalId            String?           @unique
  deleted               Boolean           @default(false)
  autoApproved          Boolean           @default(false)
  verificationStatus    String? // VERIFIED | PROVISIONAL | DISPUTED | DEPRECATED
  openAlexId            String?
  metadata              Json?
  epistemicStatus       String? // confirmed | candidate | retracted | contested | active_trial | completed_trial | registered_trial | approved | settled_judgment | contested_dissent | false_positive
  epistemicAxis         String? // RECORDED | SETTLED | CONTESTED | OPEN | UNRESOLVABLE (5-way axis, replaces currentStatus)

  parent   Claim?  @relation("ClaimHierarchy", fields: [parentClaimId], references: [id])
  children Claim[] @relation("ClaimHierarchy")

  edges                    Edge[]
  metaEdges                MetaEdge[]
  suggestedThresholdEvents SuggestedThresholdEvent[]
  thresholdEvents          ThresholdEvent[]
  topics                   ClaimTopic[]
  bookClaimMatches         BookClaimMatch[]
  historicalEvents         ClaimHistoricalEvent[]
  polityLinks              PolityClaim[]
  bookmarks                Bookmark[]
  relationsFrom            ClaimRelation[] @relation("ClaimRelationFrom")
  relationsTo              ClaimRelation[] @relation("ClaimRelationTo")
  billCoverage             BillCoverage?

  @@index([ingestedBy])
  @@index([claimType])
  @@index([currentStatus])
  @@index([verificationStatus])
  @@index([createdAt])
  @@index([claimEmergedAt])
  @@index([parentClaimId])
  @@index([openAlexId])
  @@index([deleted, parentClaimId, claimType])
  @@index([deleted, parentClaimId, claimType, createdAt])
  @@index([deleted, parentClaimId, claimType, verificationStatus])
  @@index([deleted, ingestedBy])
  @@index([epistemicStatus])
  @@index([epistemicAxis])
}

model Source {
  id               String            @id @default(cuid())
  name             String
  url              String?
  publishedAt      DateTime?
  methodologyType  String // primary | derivative | opinion
  createdAt        DateTime          @default(now())
  ingestedBy       String            @default("manual")
  humanReviewed    Boolean           @default(false)
  reviewConfidence ReviewConfidence?
  reviewedAt       DateTime?
  reviewedBy       String?
  externalId       String?           @unique
  deleted          Boolean           @default(false)
  autoApproved     Boolean           @default(false)

  edges                    Edge[]
  metaEdgesActed           MetaEdge[]                @relation("MetaEdgeActor")
  credibilityEvents        SourceCredibilityEvent[]
  relationshipsA           SourceRelationship[]      @relation("RelationshipSourceA")
  relationshipsB           SourceRelationship[]      @relation("RelationshipSourceB")
  thresholdEventsTriggered ThresholdEvent[]          @relation("ThresholdTriggerSource")
  suggestedEventsTriggered SuggestedThresholdEvent[] @relation("SuggestedTriggerSource")
  politicalContext         PoliticalContext?
  legislativeVotes         LegislativeVote[]
  wikidataLink             WikidataLink?

  @@index([ingestedBy])
  @@index([createdAt])
  @@index([deleted, ingestedBy])
}

model SourceRelationship {
  id        String   @id @default(cuid())
  sourceAId String
  sourceBId String
  type      String // funder_of | affiliated_with | co_authored_with | employed_by
  createdAt DateTime @default(now())

  sourceA Source @relation("RelationshipSourceA", fields: [sourceAId], references: [id])
  sourceB Source @relation("RelationshipSourceB", fields: [sourceBId], references: [id])

  @@index([sourceAId])
  @@index([sourceBId])
}

model SourceCredibilityEvent {
  id        String   @id @default(cuid())
  sourceId  String
  eventType String // CREDIBILITY_DOWNGRADED | RESTORED
  reason    String
  createdAt DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
}

// No score field — current score = latest EdgeRevision
model Edge {
  id               String            @id @default(cuid())
  sourceId         String
  claimId          String
  type             String // FOR | AGAINST | CITES | RETRACTS | CORRECTED
  evidenceType     String            @default("EVIDENTIARY") // EVIDENTIARY | PROCEDURAL | ARGUMENTATIVE
  deleted          Boolean           @default(false)
  createdAt        DateTime          @default(now())
  ingestedBy       String            @default("manual")
  humanReviewed    Boolean           @default(false)
  reviewConfidence ReviewConfidence?
  reviewedAt       DateTime?
  reviewedBy       String?
  autoApproved     Boolean           @default(false)

  source    Source         @relation(fields: [sourceId], references: [id])
  claim     Claim          @relation(fields: [claimId], references: [id])
  revisions EdgeRevision[]
  metaEdges MetaEdge[]

  @@index([sourceId])
  @@index([claimId])
  @@index([createdAt])
  @@index([deleted, claimId])
  @@index([deleted, sourceId])
}

// Source of truth for all scores — initial score written here on Edge creation
model EdgeRevision {
  id         String   @id @default(cuid())
  edgeId     String
  priorScore Int?
  newScore   Int
  reason     String?
  changedAt  DateTime @default(now())

  edge Edge @relation(fields: [edgeId], references: [id])

  @@index([edgeId])
}

// Edges targeting other edges — suppression, labels, demotion
model MetaEdge {
  id               String            @id @default(cuid())
  actorSourceId    String
  targetEdgeId     String
  claimId          String
  type             String // SUPPRESSED | AMPLIFIED | LABELED | DEMOTED
  reason           String?
  deleted          Boolean           @default(false)
  createdAt        DateTime          @default(now())
  ingestedBy       String            @default("manual")
  humanReviewed    Boolean           @default(false)
  reviewConfidence ReviewConfidence?
  reviewedAt       DateTime?
  reviewedBy       String?

  actorSource Source @relation("MetaEdgeActor", fields: [actorSourceId], references: [id])
  targetEdge  Edge   @relation(fields: [targetEdgeId], references: [id])
  claim       Claim  @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([targetEdgeId])
  @@index([actorSourceId])
}

// AI writes here — not authoritative
model SuggestedThresholdEvent {
  id                  String   @id @default(cuid())
  claimId             String
  aiReasoning         String
  evidenceSnapshot    String // JSON
  triggeredBySourceId String? // nullable FK — the source the AI thinks resolved the claim
  createdAt           DateTime @default(now())

  claim             Claim           @relation(fields: [claimId], references: [id])
  triggeredBySource Source?         @relation("SuggestedTriggerSource", fields: [triggeredBySourceId], references: [id])
  thresholdEvent    ThresholdEvent?

  @@index([claimId])
  @@index([triggeredBySourceId])
}

// Humans promote suggestions here — the receipt
model ThresholdEvent {
  id                  String            @id @default(cuid())
  claimId             String
  suggestedEventId    String?           @unique
  confirmedBy         String
  triggeredBy         String // free text — e.g. "FDA NDA approval"
  triggeredBySourceId String? // nullable FK — the auditable resolver source
  note                String?
  evidenceSnapshot    String // JSON
  createdAt           DateTime          @default(now())
  ingestedBy          String            @default("manual")
  humanReviewed       Boolean           @default(false)
  reviewConfidence    ReviewConfidence?
  reviewedAt          DateTime?
  reviewedBy          String?
  deleted             Boolean           @default(false)
  autoApproved        Boolean           @default(false)

  claim             Claim                    @relation(fields: [claimId], references: [id])
  suggestedEvent    SuggestedThresholdEvent? @relation(fields: [suggestedEventId], references: [id])
  triggeredBySource Source?                  @relation("ThresholdTriggerSource", fields: [triggeredBySourceId], references: [id])

  @@index([claimId])
  @@index([triggeredBySourceId])
  @@index([createdAt])
}

model Topic {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String?
  domain          String
  parentTopicId   String?
  parentTopic     Topic?         @relation("TopicHierarchy", fields: [parentTopicId], references: [id])
  children        Topic[]        @relation("TopicHierarchy")
  claims          ClaimTopic[]
  createdAt       DateTime       @default(now())
  academicFieldId Int?
  academicField   AcademicField? @relation("TopicAcademicField", fields: [academicFieldId], references: [id])

  @@index([domain])
  @@index([parentTopicId])
  @@index([academicFieldId])
}

model ClaimTopic {
  claimId   String
  topicId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
  topic     Topic    @relation(fields: [topicId], references: [id])
  createdAt DateTime @default(now())

  @@id([claimId, topicId])
  @@index([topicId])
  @@index([claimId])
}

model AcademicField {
  id        Int             @id @default(autoincrement())
  name      String
  slug      String          @unique
  parentId  Int?
  parent    AcademicField?  @relation("AcademicFieldHierarchy", fields: [parentId], references: [id])
  children  AcademicField[] @relation("AcademicFieldHierarchy")
  level     Int
  createdAt DateTime        @default(now())
  topics    Topic[]         @relation("TopicAcademicField")

  @@index([parentId])
  @@index([level])
}

// AI job queue stub — no worker in v1
model AiJob {
  id           String   @id @default(cuid())
  jobType      String // CLASSIFY_SOURCE | DETECT_CONTRADICTIONS | PROPOSE_THRESHOLD
  inputPayload String // JSON
  status       String   @default("pending") // pending | running | done | failed
  result       String?
  createdAt    DateTime @default(now())
}

model Feedback {
  id          String   @id @default(cuid())
  body        String
  pageContext String?
  email       String?
  submittedAt DateTime @default(now())
}

model PoliticalContext {
  id                String    @id @default(cuid())
  sourceId          String    @unique
  source            Source    @relation(fields: [sourceId], references: [id])
  country           String
  enactmentDate     DateTime?
  headOfGovernment  String?
  hogParty          String?
  hogWikidataId     String?
  governingParty    String?
  majorityType      String? // "majority", "minority", "coalition", "decree"
  majoritySeats     Int?
  totalSeats        Int?
  coalitionPartners String? // JSON array
  wikidataItemId    String?
  enrichedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([country])
  @@index([hogParty])
  @@index([headOfGovernment])
}

model LegislativeVote {
  id               String       @id @default(cuid())
  sourceId         String
  source           Source       @relation(fields: [sourceId], references: [id])
  chamber          String
  yesCount         Int?
  noCount          Int?
  abstainCount     Int?
  totalSeats       Int?
  passageThreshold String? // "simple_majority", "supermajority", "unanimous", etc.
  voteDate         DateTime?
  passageType      String? // "legislative_vote", "executive_decree", "committee_only"
  byPartyJson      String? // JSON: {PartyName: {yes: N, no: N, abstain: N}, ...}
  dataSource       String? // "govtrack", "theyworkforyou", "wikidata", etc.
  result           String? // "passed" | "failed" | "tied" | "unknown"
  topics           String? // JSON array: ["health", "defense", "environment"]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  memberVotes      MemberVote[]
  historicalEvents HistoricalEventVote[]
  polityVotes      PolityVote[]

  @@index([sourceId])
  @@index([result])
}

model MemberVote {
  id                String          @id @default(cuid())
  legislativeVoteId String
  legislativeVote   LegislativeVote @relation(fields: [legislativeVoteId], references: [id])
  memberName        String
  memberState       String?
  memberParty       String?
  memberId          String? // bioguide ID
  chamber           String // "House of Representatives" | "Senate"
  vote              String // "Yea" | "Nay" | "Not Voting" | "Present"
  createdAt         DateTime        @default(now())

  @@index([legislativeVoteId])
  @@index([memberId])
}

model Polity {
  id               String                  @id @default(cuid())
  name             String
  countryCode      String?
  governmentType   String // "democracy"|"republic"|"monarchy"|"empire"|"fascist"|"communist"|"authoritarian"|"theocracy"|"city_state"|"tribal"|"colonial"|"other"
  startYear        Int? // can be negative (BCE)
  endYear          Int? // null = still active
  wikidataId       String?                 @unique
  successorOf      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  historicalEvents HistoricalEventPolity[]
  polityVotes      PolityVote[]
  polityClaimLinks PolityClaim[]
}

// Wikidata cross-reference enrichment — links Source records to Wikidata Q-numbers.
// Enrichment only; never primary HARD_FACT source. One record per source (best match wins).
model WikidataLink {
  id            String   @id @default(cuid())
  sourceId      String   @unique
  source        Source   @relation(fields: [sourceId], references: [id])
  wikidataQid   String // e.g., "Q189760" (without "wd:" prefix)
  wikidataLabel String? // entity label from Wikidata, for readability
  matchMethod   String // "p3306_un_symbol" | "p5765_courtlistener" | "title_jurisdiction"
  confidence    String // "high" | "medium" | "low"
  enrichedAt    DateTime @default(now())

  @@index([wikidataQid])
  @@index([matchMethod])
}

model Book {
  id          String      @id @default(cuid())
  title       String
  author      String?
  sourceUrl   String?
  ingestedAt  DateTime    @default(now())
  chunks      BookChunk[]

  @@index([ingestedAt])
}

model BookChunk {
  id             String      @id @default(cuid())
  bookId         String
  chapterNum     Int?
  pageNum        Int?
  paragraphIndex Int
  text           String

  book   Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  claims BookClaim[]

  @@index([bookId])
  @@index([bookId, paragraphIndex])
}

model BookClaim {
  id            String           @id @default(cuid())
  chunkId       String
  claimText     String
  positionIndex Int

  chunk   BookChunk        @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  matches BookClaimMatch[]

  @@index([chunkId])
  @@index([positionIndex])
}

model BookClaimMatch {
  id              String  @id @default(cuid())
  bookClaimId     String
  claimId         String
  similarityScore Float
  matchType       String // SUPPORTS | CONTRADICTS | RELATED | UNVERIFIED
  reason          String?

  bookClaim BookClaim @relation(fields: [bookClaimId], references: [id], onDelete: Cascade)
  claim     Claim     @relation(fields: [claimId], references: [id])

  @@index([bookClaimId])
  @@index([claimId])
}

model ConstituentOpinion {
  id           String   @id @default(cuid())
  state        String // e.g. "CA", "TX"
  district     String? // e.g. "CA-12" — null means state-wide aggregate
  year         Int
  topicSlug    String // matches LegislativeVote.topics entries (snake_case) — e.g. "health"
  supportPct   Float // 0-100; % of respondents supporting the affirmative position
  sampleSize   Int // number of valid respondents in this aggregate
  source       String // e.g. "cces_cumulative_2006_2024"
  questionCode String? // CCES variable id (e.g. "CC18_320a")
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([state, district, year, topicSlug, questionCode])
  @@index([year])
  @@index([state])
  @@index([topicSlug])
  @@index([state, year, topicSlug])
}

model HistoricalEvent {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  startDate   DateTime?
  endDate     DateTime?
  category    String?  // DIPLOMATIC | INTELLIGENCE | MILITARY | LEGISLATIVE
  createdAt   DateTime @default(now())
  claims      ClaimHistoricalEvent[]
  votes       HistoricalEventVote[]
  polities    HistoricalEventPolity[]

  @@index([category])
  @@index([startDate])
}

model ClaimHistoricalEvent {
  claimId           String
  historicalEventId String
  claim             Claim           @relation(fields: [claimId], references: [id])
  event             HistoricalEvent @relation(fields: [historicalEventId], references: [id])
  createdAt         DateTime        @default(now())

  @@id([claimId, historicalEventId])
  @@index([historicalEventId])
  @@index([claimId])
}

model HistoricalEventVote {
  id          String          @id @default(cuid())
  eventId     String
  voteId      String
  matchReason String
  createdAt   DateTime        @default(now())
  event       HistoricalEvent @relation(fields: [eventId], references: [id])
  vote        LegislativeVote @relation(fields: [voteId], references: [id])

  @@unique([eventId, voteId])
  @@index([eventId])
  @@index([voteId])
}

model HistoricalEventPolity {
  id        String          @id @default(cuid())
  eventId   String
  polityId  String
  role      String
  createdAt DateTime        @default(now())
  event     HistoricalEvent @relation(fields: [eventId], references: [id])
  polity    Polity          @relation(fields: [polityId], references: [id])

  @@unique([eventId, polityId])
  @@index([eventId])
  @@index([polityId])
}

model PolityVote {
  id          String          @id @default(cuid())
  polityId    String
  voteId      String
  matchMethod String          // "auto_country_date" | "manual"
  createdAt   DateTime        @default(now())

  polity Polity          @relation(fields: [polityId], references: [id])
  vote   LegislativeVote @relation(fields: [voteId], references: [id])

  @@unique([polityId, voteId])
  @@index([polityId])
  @@index([voteId])
}

model PolityClaim {
  id          String   @id @default(cuid())
  polityId    String
  claimId     String
  matchMethod String   // "auto_country_date" | "manual"
  createdAt   DateTime @default(now())

  polity Polity @relation(fields: [polityId], references: [id])
  claim  Claim  @relation(fields: [claimId], references: [id])

  @@unique([polityId, claimId])
  @@index([polityId])
  @@index([claimId])
}

model Profile {
  id        String     @id @default(uuid())
  key       String     @unique
  createdAt DateTime   @default(now())
  bookmarks Bookmark[]
}

model Bookmark {
  id        String   @id @default(uuid())
  profileId String
  claimId   String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  claim   Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([profileId, claimId])
  @@index([profileId])
  @@index([claimId])
}

model BillCoverage {
  id           Int      @id @default(autoincrement())
  claimId      String   @unique
  claim        Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  articleCount Int      @default(0)
  topHeadlines Json? // array of { headline: string, url: string, date: string }
  searchQuery  String
  lastChecked  DateTime @default(now())

  @@index([articleCount])
}

model ClaimRelation {
  id               String   @id @default(cuid())
  fromClaimId      String
  toClaimId        String
  relationType     String // "cites" | "cited_by" | "related" | "OUTCOME" | "STATUS_UPDATE" | "SUPERSEDED_BY" | "REVERSED" | "EXPANDED"
  year             Int?
  followUpContext  Json?    // metadata for follow-up relation types (confidence, heuristic, notes)
  createdAt        DateTime @default(now())

  fromClaim Claim @relation("ClaimRelationFrom", fields: [fromClaimId], references: [id], onDelete: Cascade)
  toClaim   Claim @relation("ClaimRelationTo", fields: [toClaimId], references: [id], onDelete: Cascade)

  @@unique([fromClaimId, toClaimId, relationType])
  @@index([fromClaimId])
  @@index([toClaimId])
  @@index([fromClaimId, relationType])
  @@index([toClaimId, relationType])
}

model WatchedTopic {
  id          String    @id @default(cuid())
  keyword     String    @unique
  label       String
  createdAt   DateTime  @default(now())
  lastAlertAt DateTime?
}
