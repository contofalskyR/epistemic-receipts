{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(bash -n:*)",
      "Bash(npx tsc:*)",
      "Bash(node node_modules/typescript/bin/tsc:*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma validate)"
    ],
    "deny": [
      "Read(./.env*)",
      "Bash(cat .env*)"
    ]
  }
}
