#!/usr/bin/env bash
# pre-push secret scan (SECURITY-ASSESSMENT-2026-07-09 finding #16).
# CI gitleaks runs after the push — on a public repo that's too late.
# This hook scans every outgoing commit before it leaves the machine.
#
# Setup (once per clone):  git config core.hooksPath .githooks
# Requires gitleaks >= 8.19 on PATH: https://github.com/gitleaks/gitleaks#installing
# Emergency bypass (only if you are certain there is no secret): git push --no-verify
set -uo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-push: gitleaks not found on PATH — refusing to push unscanned commits." >&2
  echo "pre-push: install it (https://github.com/gitleaks/gitleaks#installing)" >&2
  echo "pre-push: or bypass once with: git push --no-verify" >&2
  exit 1
fi

zero="0000000000000000000000000000000000000000"
status=0

# stdin: <local ref> SP <local sha> SP <remote ref> SP <remote sha> per ref being pushed
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue # ref deletion — nothing to scan
  if [ "$remote_sha" = "$zero" ]; then
    # new remote branch — scan everything not already on some origin ref
    log_opts="$local_sha --not --remotes=origin"
  else
    log_opts="$remote_sha..$local_sha"
  fi
  if ! gitleaks git --log-opts="$log_opts" --redact --exit-code 1 .; then
    status=1
  fi
done

if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "pre-push: gitleaks found potential secrets in outgoing commits — push blocked." >&2
fi
exit "$status"
